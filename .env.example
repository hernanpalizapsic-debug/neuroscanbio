# NeuroScan — env vars requeridos para deploy (Vercel).
# Copiar a .env.local para dev y setear en Vercel Project Settings para prod.

# Firebase (MISMO proyecto que Reset 3.0)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL de Reset 3.0 (para redirigir de vuelta al terminar la evaluación).
# En dev, poner http://localhost:5173 o el puerto que uses.
VITE_RESET_URL=https://reset30.vercel.app
